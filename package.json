{
  "name": "migrate-wagmi-v3",
  "version": "1.0.0",
  "description": "Automated codemod suite for wagmi v2→v3 and Inngest v3→v4 migrations",
  "main": "bin/index.js",
  "bin": {
    "migrate-wagmi-v3": "./bin/index.js"
  },
  "scripts": {
    "test:wagmi": "cd packages/codemod && npm test",
    "test:inngest": "cd packages/inngest-codemod && npm test",
    "build:wagmi": "cd packages/codemod && npx tsc",
    "build:inngest": "cd packages/inngest-codemod && npx tsc",
    "build": "npm run build:wagmi && npm run build:inngest"
  },
  "keywords": ["codemod", "wagmi", "inngest", "migration", "web3"],
  "author": "web3smallie",
  "license": "MIT"
}